{
  "version": 2,
  "rewrites": [
    { "source": "/", "destination": "/api/index-html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors https://trello.com https://*.trello.com"
        }
      ]
    }
  ]
}
