# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — DO NOT commit it.

# Trello Power-Up API key (public — same value as in .env / Vercel TRELLO_API_KEY)
TRELLO_API_KEY=

# Your personal Trello user token with read,write scope.
# Generate at https://trello.com/app-key (or reuse TRELLO_TOKEN from .env)
TRELLO_USER_TOKEN=

# Short ID of the dedicated test board.
# From URL pattern: https://trello.com/b/{shortId}/board-name
TRELLO_TEST_BOARD_ID=

# Optional: override storageState path (default: ./storageState.json)
# STORAGE_STATE_PATH=./storageState.json
